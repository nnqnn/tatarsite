generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Language {
  RU
  TT
  EN
}

enum PlaceCategory {
  CULTURE
  FOOD
  NATURE
  EVENTS
  CRAFTS
  HISTORY
  HIDDEN
  FESTIVALS
  MARKET
}

enum ReactionType {
  LIKE
  DISLIKE
}

model User {
  id                   String           @id @default(cuid())
  email                String           @unique
  passwordHash         String
  displayName          String
  avatarUrl            String?
  bio                  String?
  language             Language         @default(RU)
  onboardingCompletedAt DateTime?
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt

  preferences          UserPreference[]
  places               Place[]
  reactions            PlaceReaction[]
  comments             Comment[]
  refreshTokens        RefreshToken[]
}

model UserPreference {
  id          String   @id @default(cuid())
  userId      String
  interestKey PlaceCategory
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, interestKey])
  @@index([interestKey])
}

model Place {
  id          String      @id @default(cuid())
  authorId    String
  title       String
  description String
  category    PlaceCategory
  isEvent     Boolean     @default(false)
  eventStartAt DateTime?
  eventEndAt   DateTime?
  latitude    Float
  longitude   Float
  address     String?
  city        String?
  isPublished Boolean     @default(true)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  deletedAt   DateTime?

  author    User            @relation(fields: [authorId], references: [id], onDelete: Restrict)
  images    PlaceImage[]
  reactions PlaceReaction[]
  comments  Comment[]

  @@index([authorId])
  @@index([category])
  @@index([isEvent, eventStartAt])
  @@index([createdAt])
  @@index([latitude, longitude])
}

model PlaceImage {
  id        String   @id @default(cuid())
  placeId   String
  storageKey String?
  url       String
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  place Place @relation(fields: [placeId], references: [id], onDelete: Cascade)

  @@index([placeId, sortOrder])
}

model PlaceReaction {
  id           String       @id @default(cuid())
  userId       String
  placeId      String
  reactionType ReactionType
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  place Place @relation(fields: [placeId], references: [id], onDelete: Cascade)

  @@unique([userId, placeId])
  @@index([placeId])
  @@index([reactionType])
}

model Comment {
  id              String    @id @default(cuid())
  placeId          String
  authorId         String
  parentCommentId  String?
  body             String
  isDeleted        Boolean   @default(false)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  place Place @relation(fields: [placeId], references: [id], onDelete: Cascade)
  author User @relation(fields: [authorId], references: [id], onDelete: Cascade)

  parent   Comment?  @relation("CommentReplies", fields: [parentCommentId], references: [id], onDelete: Cascade)
  replies  Comment[] @relation("CommentReplies")

  @@index([placeId, createdAt])
  @@index([parentCommentId])
}

model RefreshToken {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}
